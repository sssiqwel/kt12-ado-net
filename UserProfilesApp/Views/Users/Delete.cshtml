@model User

@{
    ViewData["Title"] = $"Delete user #{Model.Id}";
}

<h1 class="h3">@ViewData["Title"]</h1>

<div class="alert alert-warning mt-3">
    Это действие удалит пользователя и связанный профиль (каскадное удаление).
</div>

<div class="card">
    <div class="card-body">
        <div><strong>Username:</strong> @Model.UserName</div>
        <div><strong>Email:</strong> @Model.Email</div>
        <div><strong>Profile:</strong> @Model.Profile.FirstName @Model.Profile.LastName</div>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
</form>

