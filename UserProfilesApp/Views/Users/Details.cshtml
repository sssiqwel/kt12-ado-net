@model User

@{
    ViewData["Title"] = $"User #{Model.Id}";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">User</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.UserName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("u")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Profile</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">First name</dt>
                    <dd class="col-sm-8">@Model.Profile.FirstName</dd>
                    <dt class="col-sm-4">Last name</dt>
                    <dd class="col-sm-8">@Model.Profile.LastName</dd>
                    <dt class="col-sm-4">Birth date</dt>
                    <dd class="col-sm-8">@Model.Profile.BirthDate?.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-4">Bio</dt>
                    <dd class="col-sm-8">@Model.Profile.Bio</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to list</a>
</div>

